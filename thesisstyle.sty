\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{thesisstyle}[2026/06/10 Custom thesis style]

% =====================================================
% 1. Font and Language Setup
% =====================================================
\RequirePackage{fontspec}
\RequirePackage{polyglossia}

\setmainlanguage{english}
\setotherlanguage{khmer}

% Main English fonts
\setmainfont{Times New Roman}
\setmonofont{DejaVu Sans Mono}

% Khmer fonts
\newfontfamily\khmerfont[
    Script=Khmer,
    Scale=1.0
]{Khmer OS Battambang}

\newfontfamily\khmoul[
    Script=Khmer,
    Scale=1.0,
    BoldFont=Khmer OS Muol Light
]{Khmer OS Muol Light}

\newfontfamily\khsr[
    Script=Khmer,
    Scale=1.0
]{Khmer OS Siemreap}

% Khmer text line breaking
\XeTeXlinebreaklocale "khm"
\XeTeXlinebreakskip = 0pt plus 0.5pt minus 0.25pt

% Khmer field row for cover page
\newcommand{\KHCoverRow}[2]{%
    {\khmoul\fontsize{13pt}{15pt}\selectfont #1} &
    {\khmoul\fontsize{13pt}{15pt}\selectfont : #2} \\[.45cm]
}

% =====================================================
% 2. Page Layout
% =====================================================
\RequirePackage[
    a4paper,
    margin=2.5cm,
    top=2cm,
    bottom=2.5cm
]{geometry}

% =====================================================
% 3. Line Spacing and Paragraph Formatting
% =====================================================
\RequirePackage{setspace}
\onehalfspacing

% Paragraph style
\setlength{\parindent}{0pt}
\setlength{\parskip}{8pt}

% =====================================================
% 4. Common Packages
% =====================================================
\RequirePackage{eso-pic}
\RequirePackage{graphicx}
\RequirePackage{mdframed}
\RequirePackage{tabularx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{array}
\RequirePackage{xcolor}
\RequirePackage{caption}
\RequirePackage{float}
\RequirePackage{etoolbox}

\RequirePackage{tikz}
\usetikzlibrary{
    positioning,
    arrows.meta,
    shapes.geometric,
    shapes.misc,
    calc,
    fit
}

% =====================================================
% 5. Text Wrapping, Code Names, and List Formatting
% =====================================================
\RequirePackage{microtype}
\RequirePackage{xurl}
\RequirePackage{seqsplit}
\RequirePackage{enumitem}

% Helps LaTeX reduce overfull lines globally
\setlength{\emergencystretch}{3em}

% Better URL breaking
\Urlmuskip=0mu plus 1mu

% Safe commands for code, package, class, function, and file names
\providecommand{\code}[1]{\texttt{\seqsplit{#1}}}
\providecommand{\pkg}[1]{\texttt{\seqsplit{#1}}}
\providecommand{\filepath}[1]{\texttt{\seqsplit{#1}}}

% Safer list formatting
\setlist[enumerate]{
    leftmargin=1.25cm,
    itemsep=0.35em,
    topsep=0.5em
}

\setlist[itemize]{
    leftmargin=1.25cm,
    itemsep=0.35em,
    topsep=0.5em
}

% =====================================================
% 6. Table of Contents, List of Figures, List of Tables
% =====================================================
\RequirePackage{tocloft}

% Rename TOC, LOF, and LOT titles
\gappto\captionsenglish{%
    \renewcommand{\contentsname}{TABLE OF CONTENTS}%
    \renewcommand{\listfigurename}{LIST OF FIGURES}%
    \renewcommand{\listtablename}{LIST OF TABLES}%
}

% TOC depth
% 2 = show chapters, sections, and subsections
% 3 = number subsubsections in the document
\setcounter{tocdepth}{2}
\setcounter{secnumdepth}{3}

% Dotted leader style
\renewcommand{\cftdotsep}{1}

% -----------------------------------------------------
% Remove extra chapter gap in List of Figures / Tables
% This makes every LOF / LOT entry spacing equal.
% -----------------------------------------------------
\makeatletter
\patchcmd{\@chapter}
    {\addtocontents{lof}{\protect\addvspace{10\p@}}}
    {}
    {}{}

\patchcmd{\@chapter}
    {\addtocontents{lot}{\protect\addvspace{10\p@}}}
    {}
    {}{}
\makeatother

% -----------------------------------------------------
% TOC chapter format
% Example:
% CHAPTER 1 : INTRODUCTION ................. 1
% -----------------------------------------------------
\renewcommand{\cftchappresnum}{CHAPTER~}
\renewcommand{\cftchapaftersnum}{~:~}

% Keep chapter entries bold in TOC
\renewcommand{\cftchapfont}{\bfseries}
\renewcommand{\cftchappagefont}{\bfseries}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}

% TOC spacing
\setlength{\cftbeforechapskip}{3pt}
\setlength{\cftbeforesecskip}{3pt}
\setlength{\cftbeforesubsecskip}{3pt}

% TOC indentation and number width
\setlength{\cftchapindent}{0em}
\setlength{\cftchapnumwidth}{7.5em}

\setlength{\cftsecindent}{1.5em}
\setlength{\cftsecnumwidth}{3em}

\setlength{\cftsubsecindent}{3.5em}
\setlength{\cftsubsecnumwidth}{4em}

% Section and subsection entries use normal font
\renewcommand{\cftsecfont}{\normalfont}
\renewcommand{\cftsecpagefont}{\normalfont}
\renewcommand{\cftsubsecfont}{\normalfont}
\renewcommand{\cftsubsecpagefont}{\normalfont}

% -----------------------------------------------------
% Page number spacing in TOC / LOF / LOT
% Important: wide enough for page numbers like 50, 100, etc.
% -----------------------------------------------------
\cftsetpnumwidth{2.5em}
\cftsetrmarg{3.5em}

% Center TOC title
\renewcommand{\cfttoctitlefont}{\hspace*{\fill}\Large\bfseries}
\renewcommand{\cftaftertoctitle}{\hspace*{\fill}}

% Center List of Figures title
\renewcommand{\cftloftitlefont}{\hspace*{\fill}\Large\bfseries}
\renewcommand{\cftafterloftitle}{\hspace*{\fill}}

% Center List of Tables title
\renewcommand{\cftlottitlefont}{\hspace*{\fill}\Large\bfseries}
\renewcommand{\cftafterlottitle}{\hspace*{\fill}}

% =====================================================
% 7. Figure and Table Numbering
% =====================================================

% Number figures and tables by chapter
% Example:
% Figure 1.1, Figure 1.2, Figure 2.1
% Table 1.1, Table 1.2, Table 2.1
\renewcommand{\thefigure}{\thechapter.\arabic{figure}}
\renewcommand{\thetable}{\thechapter.\arabic{table}}

% Reset figure and table numbers at every chapter
\makeatletter
\@addtoreset{figure}{chapter}
\@addtoreset{table}{chapter}
\makeatother

% Caption format in document
% Example:
% Figure 1.1: System Architecture
\captionsetup[figure]{
    name=Figure,
    labelfont=bf,
    labelsep=colon
}

\captionsetup[table]{
    name=Table,
    labelfont=bf,
    labelsep=colon
}

% -----------------------------------------------------
% List of Figures format
% Example:
% Figure 1.1: System Architecture ............ 10
% -----------------------------------------------------
\renewcommand{\cftfigpresnum}{Figure~}
\renewcommand{\cftfigaftersnum}{:\ }
\renewcommand{\cftfigleader}{\cftdotfill{\cftdotsep}}

\setlength{\cftfigindent}{0pt}
\setlength{\cftfignumwidth}{6.8em}
\setlength{\cftbeforefigskip}{4pt}

% -----------------------------------------------------
% List of Tables format
% Example:
% Table 1.1: Summary of Results .............. 12
% -----------------------------------------------------
\renewcommand{\cfttabpresnum}{Table~}
\renewcommand{\cfttabaftersnum}{:\ }
\renewcommand{\cfttableader}{\cftdotfill{\cftdotsep}}

\setlength{\cfttabindent}{0pt}
\setlength{\cfttabnumwidth}{6.8em}
\setlength{\cftbeforetabskip}{4pt}

% =====================================================
% 8. Chapter and Section Title Formatting
% =====================================================
\RequirePackage{titlesec}

% -----------------------------------------------------
% Chapter title format
% Example:
% CHAPTER 1 : INTRODUCTION
% -----------------------------------------------------
\titleformat{\chapter}
    {\bfseries\fontsize{14pt}{21pt}\selectfont}
    {CHAPTER \thechapter\ :}
    {12pt}
    {\MakeUppercase}

% -----------------------------------------------------
% Numberless chapter title format
% Example:
% ABSTRACT
% ACKNOWLEDGEMENT
% -----------------------------------------------------
\titleformat{name=\chapter,numberless}
    {\centering\bfseries\fontsize{14pt}{21pt}\selectfont}
    {}
    {0pt}
    {\MakeUppercase}

\titlespacing*{\chapter}{0cm}{0pt}{12pt}

% -----------------------------------------------------
% Section title format
% Example:
% 1.1. Presentation of Internship
% -----------------------------------------------------
\titleformat{\section}
    {\bfseries\fontsize{12pt}{18pt}\selectfont}
    {\thesection.}
    {0.5cm}
    {}

\titlespacing*{\section}{0cm}{12pt}{6pt}

% -----------------------------------------------------
% Subsection title format
% Example:
% 1.1.1. Objectives
% -----------------------------------------------------
\titleformat{\subsection}
    {\bfseries\fontsize{11pt}{16.5pt}\selectfont}
    {\thesubsection.}
    {0.5cm}
    {}

\titlespacing*{\subsection}{0cm}{10pt}{6pt}

% -----------------------------------------------------
% Subsubsection title format
% Example:
% 1.1.1.1. Detailed Explanation
% -----------------------------------------------------
\titleformat{\subsubsection}
    {\bfseries\fontsize{11pt}{16.5pt}\selectfont}
    {\thesubsubsection.}
    {0.5cm}
    {}

\titlespacing*{\subsubsection}{0cm}{8pt}{4pt}

% =====================================================
% 9. Citations, Bibliography, and Hyperlinks
% =====================================================
\RequirePackage[
    backend=biber,
    style=ieee,
    sorting=none
]{biblatex}

\DefineBibliographyStrings{english}{%
    bibliography = {REFERENCES},
    references = {REFERENCES},
}

\RequirePackage{hyperref}
\RequirePackage{bookmark}

\hypersetup{
    colorlinks=true,
    linkcolor=black,
    citecolor=black,
    urlcolor=black
}

% =====================================================
% 10. Custom Commands
% =====================================================

% Centered low-opacity watermark using TikZ
\newcommand{\Watermark}{%
    \AddToShipoutPictureBG*{%
        \begin{tikzpicture}[remember picture, overlay]
            \node[
                opacity=0.2,
                anchor=center
            ] at (current page.center) {%
                \includegraphics[
                    width=0.55\paperwidth
                ]{figures/schools/watermark.png}%
            };
        \end{tikzpicture}%
    }%
}

% Paragraph manual indent shortcut, only use when needed
\providecommand{\hs}{\hspace*{1.25cm}}

% Reference commands
\providecommand{\figref}[1]{Figure~\ref{#1}}
\providecommand{\tabref}[1]{Table~\ref{#1}}
\providecommand{\chapref}[1]{Chapter~\ref{#1}}
\providecommand{\secref}[1]{Section~\ref{#1}}

@article{has2023gradientcobra,
  place        = {The Netherlands},
  title        = {Gradient COBRA: A kernel-based consensual aggregation for regression: Kernel-based Aggregation for Regression},
  volume       = {3},
  url          = {https://jdssv.org/index.php/jdssv/article/view/70},
  doi          = {10.52933/jdssv.v3i2.70},
  abstractnote = {&amp;lt;p&amp;gt;In this article, we introduce a kernel-based consensual aggregation method for regression problems. We aim to flexibly combine individual regression estimators r&amp;lt;sub&amp;gt;1&amp;lt;/sub&amp;gt;, ..., r&amp;lt;sub&amp;gt;M&amp;lt;/sub&amp;gt; using a weighted average where the weights are defined based on predicted features given by all the basic estimators and some kernel function. This work extends the context of Biau et al. (2016) to a more general kernel-based framework. We show that this more general configuration also inherits the consistency of the basic consistent estimators, and the same convergence rate as in the classical method is achieved. Moreover, an optimization method based on gradient descent algorithm is proposed to efficiently and rapidly estimate the key parameter of the strategy. Various of numerical experiments carried out on several simulated and real datasets are also provided to illustrate the efficiency and accuracy of the method with the introduction of gradient descent algorithm and smoother kernel functions respectively. Moreover, a domain adaptation-like property of the method is also illustrated on a physics data provided by Commissariat à l&amp;#039;Énergie Atomique (CEA).&amp;lt;/p&amp;gt;},
  number       = {2},
  journal      = {Journal of Data Science, Statistics, and Visualisation},
  author       = {HAS, Sothea},
  year         = {2023},
}

